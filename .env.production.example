# Copy to /opt/bm-backend/.env on the VPS and fill in real values.
# This file holds the production secrets — it must NEVER be committed.

# --- Database ---------------------------------------------------------------
# Used by the postgres service in docker-compose.yml:
POSTGRES_PASSWORD=change-me-strong-password
# Used by the app. Host "postgres" = the compose service name. The password
# here must match POSTGRES_PASSWORD above (it is not auto-substituted).
DATABASE_URL=postgresql://bms_user:change-me-strong-password@postgres:5432/bms_db?schema=public

# --- Auth -------------------------------------------------------------------
JWT_SECRET=generate-a-long-random-string
JWT_REFRESH_SECRET=generate-a-different-long-random-string

# --- App --------------------------------------------------------------------
NODE_ENV=production
PORT=8000
FRONTEND_URL=https://your-frontend-domain
# Browser CORS allowlist (comma-separated origins). Falls back to FRONTEND_URL.
# Set this to your Vercel frontend origin once deployed, e.g.
# CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=https://your-frontend-domain

# --- Email ------------------------------------------------------------------
RESEND_API_KEY=re_xxx

# --- Push notifications (optional; leave unset to disable) ------------------
# Paste the full Firebase service-account JSON as a single line:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
